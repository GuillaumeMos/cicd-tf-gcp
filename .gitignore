# macOS
.DS_Store

# Editors / IDE
.idea/
.vscode/
*.swp
*.swo
*~

# Terraform working dirs and caches
**/.terraform/*
.terraform/
.terraform.lock.hcl

# Terraform state files
*.tfstate
*.tfstate.*

# Terraform plans and crash logs
*.tfplan
*.plan
crash.log
crash.*.log

# Terraform override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Terraform CLI config / credentials
.terraformrc
terraform.rc

# Local-only variable files (keep shared tfvars tracked)
*.tfvars.local
*.auto.tfvars.local

# Sensitive key/cert material
*.pem
*.key
*.p12
*.pfx

# Generic logs
*.log
